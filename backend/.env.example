# Port to run the Flask backend on (default: 8000, Hugging Face default: 7860)
PORT=8000

# Allowed CORS origins, comma-separated (e.g. https://deepshield.netlify.app)
FRONTEND_ORIGINS=*

# Optional: Path to Firebase Admin service account key JSON
# FIREBASE_SERVICE_ACCOUNT_KEY=firebase-key.json

# Optional: Raw JSON string of the Firebase service account credential
# FIREBASE_CREDENTIALS_JSON={"type": "service_account", ...}

# Optional: Hugging Face User Access Token (to avoid rate limits)
# HF_TOKEN=your_huggingface_token
